{
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 40,           // Lascia solo questa
    "margin-right": 5,
    "margin-left": 5,
    "output": "eDP-1",

    "modules-left": [
        "custom/launcher",
        "niri/workspaces",
        "niri/window"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "custom/mounts",
        "custom/backup", // L'ho aggiunto qui cosأ¬ lo vedi quando parte!
        "tray",
        "custom/updates",
        "temperature",
        "cpu",
        "memory",
        "disk",
        "custom/nightlight",
        "bluetooth",
        "pulseaudio#microphone",
        "pulseaudio",
        "battery",
        "network",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "َ±„…",
        "on-click": "fuzzel",
        "tooltip": false
    },

    "custom/power": {
        "format": "âڈ»",
        "on-click": "niri msg action quit",
        "tooltip": false
    },

    "niri/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "active": "â—ڈ",
            "default": "â—‹"
        }
    },

    "niri/window": {
        "format": "{}",
        "max-length": 40,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹ $1",
            "(.*) - kitty": " $1",
            "(.*)": "$1"
        }
    },

    "tray": {
        "icon-size": 12,
        "spacing": 10
    },

    "clock": {
        "timezone": "Europe/Rome",
        "format": "  {:%H:%M}",
        "tooltip": true,
        "tooltip-format": "  {:%A, %d %B %Y}\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "interval": 10,
        "format": "َ°کڑ",
        "format-alt-click": "click-right",
        "format-alt": "َ°کڑ {usage}%",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}% | Load: {load}"
    },

    "memory": {
        "interval": 30,
        "format": "َ°چ›",
        "format-alt-click": "click-right",
        "format-alt": "َ°چ› {used:0.1f}G",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}GB / {total:0.1f}GB ({percentage}%)"
    },

    "disk": {
        "interval": 600,
        "format": "َ°‹ٹ",
        "path": "/",
        "format-alt-click": "click-right",
        "format-alt": "َ°‹ٹ {percentage_used}%",
        "tooltip": true,
        "tooltip-format": "Disco: {used} / {total} ({percentage_used}%)",
        "states": {
            "warning": 85,
            "critical": 90
        }
    },

    "temperature": {
        "thermal-zone": 1,
        "format": "َ°”ڈ",
        "format-alt-click": "click-right",
        "format-alt": "َ°”ڈ {temperatureC}آ°C",
        "critical-threshold": 70,
        "format-critical": "َ°¸پ {temperatureC}آ°C",
        "tooltip": true,
        "tooltip-format": "Temperatura: {temperatureC}آ°C"
    },

    "battery": {
        "bat": "BAT0",
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip": true,
        "tooltip-format": "Batteria: {capacity}% ({timeTo})"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "َ°‌ں",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹‹",
            "headset": "َ°‹‹",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "َ°چ¬",
        "format-source-muted": "َ°چ­",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%-",
        "tooltip": true,
        "tooltip-format": "Mic: {volume}%"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": true,
        "tooltip-format": "Luminositأ : {percent}%"
    },

    "network": {
        "format-wifi": "َ°¤¨",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°¤­",
        "tooltip-format-wifi": "َ°¤¨ {essid} ({signalStrength}%)\nَ°©ں {ipaddr}/{cidr}",
        "tooltip-format-ethernet": "َ°ˆ€ {ifname}\nَ°©ں {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnesso",
        "max-length": 50
    },

    "custom/updates": {
        "format": "{}",
        "exec": "apt list --upgradable 2>/dev/null | tail -n +2 | wc -l | xargs -I{} echo '{} َ°ڑ°'",
        "interval": 3600,
        "tooltip": true,
        "tooltip-format": "Aggiornamenti disponibili"
    },

    "custom/mounts": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/mounts.sh waybar",
        "return-type": "json",
        "interval": 10,
        "on-click": "~/.config/waybar/scripts/mounts.sh toggle",
        "tooltip": true
    },

    "custom/backup": {
        "exec": "pgrep -x rsync > /dev/null && echo 'َ°پ¯ BACKUP' || echo ''",
        "interval": 5,
        "tooltip": false
    },

    "custom/nightlight": {
        "format": "{}",
        "return-type": "json",
        // Usa il percorso assoluto reale se non si trova in ~/.config/waybar/
        "exec": "$HOME/myconfig/waybar-niri/scripts/nightlight.sh status",
        "on-click": "$HOME/myconfig/waybar-niri/scripts/nightlight.sh toggle",
        "interval": 5
    },

    "bluetooth": {
        "format": "َ°‚¯",
        "format-disabled": "َ°‚²",
        "format-connected": "َ°‚± {num_connections}",
        "on-click": "/usr/sbin/rfkill toggle bluetooth", // <--- PERCORSO COMPLETO
        "on-click-right": "blueman-manager"
    }
}
