{
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 40,
    "margin-right": 5,
    "margin-left": 5,
    "output": "eDP-1",

    "modules-left": [
        "custom/launcher",
        "niri/workspaces",
        "niri/window"
    ],

    "modules-center": [
        "clock",
        "custom/calendar"
    ],

    "modules-right": [
        "custom/mounts",
        "custom/backup",
        "custom/updates",
        "temperature",
        "cpu",
        "memory",
        "disk",
        "custom/nightlight",
        "custom/bluetooth",
        "pulseaudio#microphone",
        "pulseaudio",
        "custom/weather",
        "battery",
        "network",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "¾▒äà",
        "on-click": "fuzzel",
        "tooltip": false
    },

    "custom/power": {
        "format": "ÔÅ╗",
        "on-click": "~/.config/waybar/scripts/powermenu.sh",
        "tooltip": true,
        "tooltip-format": "Men├╣ sessione"
    },

    "niri/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "active": "ÔùÅ",
            "default": "Ôùï"
        }
    },

    "niri/window": {
        "format": "{}",
        "max-length": 40,
        "rewrite": {
            "(.*) ÔÇö Mozilla Firefox": "¾░ê╣ $1",
            "(.*) - kitty": " $1",
            "(.*)": "$1"
        }
    },

    "tray": {
        "icon-size": 12,
        "spacing": 10
    },

    "clock": {
        "timezone": "Europe/Rome",
        "format": "  {:%H:%M}",
        "tooltip": true,
        "tooltip-format": "  {:%A, %d %B %Y}"
    },

    "custom/calendar": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/calendar.sh status",
        "interval": 60,
        "on-click": "kitty --app-id cal-tui --config ~/.config/waybar/cal-tui.conf ~/.config/waybar/scripts/cal-tui.sh",
        "on-scroll-up": "~/.config/waybar/scripts/calendar.sh prev && pkill -RTMIN+9 waybar",
        "on-scroll-down": "~/.config/waybar/scripts/calendar.sh next && pkill -RTMIN+9 waybar",
        "on-click-middle": "~/.config/waybar/scripts/calendar.sh reset && pkill -RTMIN+9 waybar",
        "signal": 9,
        "tooltip": true
    },

    "cpu": {
        "interval": 10,
        "format": "¾░ìø",
        "format-alt-click": "click-right",
        "format-alt": "¾░ìø {usage}%",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}% | Load: {load}"
    },

    "memory": {
        "interval": 30,
        "format": "¾░ÿÜ",
        "format-alt-click": "click-right",
        "format-alt": "¾░ÿÜ {used:0.1f}G",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}GB / {total:0.1f}GB ({percentage}%)"
    },

    "disk": {
        "interval": 600,
        "format": "¾░ïè",
        "path": "/",
        "format-alt-click": "click-right",
        "format-alt": "¾░ïè {percentage_used}%",
        "tooltip": true,
        "tooltip-format": "Disco: {used} / {total} ({percentage_used}%)",
        "states": {
            "warning": 85,
            "critical": 90
        }
    },

    "temperature": {
        "thermal-zone": 1,
        "format": "¾░öÅ",
        "format-alt-click": "click-right",
        "format-alt": "¾░öÅ {temperatureC}┬░C",
        "critical-threshold": 70,
        "format-critical": "¾░©ü {temperatureC}┬░C",
        "tooltip": true,
        "tooltip-format": "Temperatura: {temperatureC}┬░C"
    },

    "battery": {
        "bat": "BAT0",
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}",
        "format-charging": "¾░éä {capacity}%",
        "format-plugged": "¾░ÜÑ {capacity}%",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"],
        "tooltip": true,
        "tooltip-format": "Batteria: {capacity}% ({timeTo})"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "¾░Øƒ",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "¾░ïï",
            "hands-free": "¾░ïï",
            "headset": "¾░ïï",
            "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
        },
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "¾░ì¼",
        "format-source-muted": "¾░ì¡",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%-",
        "tooltip": true,
        "tooltip-format": "Mic: {volume}%"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {percent}%",
        "format-icons": ["¾░â×", "¾░âƒ", "¾░âá"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": true,
        "tooltip-format": "Luminosit├á: {percent}%"
    },

    "network": {
        "format-wifi": "¾░ñ¿",
        "format-ethernet": "¾░êÇ",
        "format-disconnected": "¾░ñ¡",
        "tooltip-format-wifi": "¾░ñ¿ {essid} ({signalStrength}%)\n¾░®ƒ {ipaddr}/{cidr}\n Click: reti disponibili",
        "tooltip-format-ethernet": "¾░êÇ {ifname}\n¾░®ƒ {ipaddr}/{cidr}\n Click: reti disponibili",
        "tooltip-format-disconnected": "Disconnesso\n Click: reti disponibili",
        "on-click": "python3 /home/noya/.config/waybar/wifi-menu.py",
        "on-click-right": "nmcli device wifi rescan",
        "max-length": 50
    },

    "custom/updates": {
        "format": "{}",
        "exec": "/home/noya/.config/waybar/scripts/update-sys",
        "interval": 3600,
        "on-click": "/home/noya/.config/waybar/scripts/update-sys update",
        "return-type": "json"
    },

    "custom/mounts": {
        "format": "{}",
        "exec": "/home/noya/.config/waybar/scripts/mounts.sh waybar",
        "return-type": "json",
        "interval": 10,
        "on-click": "/home/noya/.config/waybar/scripts/mounts.sh toggle",
        "tooltip": true
    },

    "custom/backup": {
        "exec": "pgrep -x rsync > /dev/null && echo '¾░ü» BACKUP' || echo ''",
        "interval": 5,
        "tooltip": false
    },

    "custom/nightlight": {
        "format": "{}",
        "return-type": "json",
        "interval": 2,
        "exec": "/home/noya/.config/waybar/scripts/nightlight.sh status",
        "on-click": "/home/noya/.config/waybar/scripts/nightlight.sh toggle"
    },

    "custom/bluetooth": {
        "exec": "~/.config/waybar/scripts/bt-status.sh",
        "interval": 5,
        "return-type": "json",
        "tooltip": true,
        "on-click": "~/.config/waybar/scripts/bt-toggle.sh",
        "on-click-right": "blueman-manager"
    },

    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 3600,
        "exec": "/home/noya/.config/waybar/scripts/wttr.py",
        "return-type": "json",
        "on-click": "fuzzel --dmenu --prompt 'Meteo  ' --width 92 --lines 14 < ~/.cache/waybar-weather-detail.txt"
    }
}
