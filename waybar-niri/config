{
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 36,
    "margin-right": 5,
    "margin-left": 5,
    "output": "eDP-1",
    "height": 40,

    "modules-left": [
        "custom/launcher",
        "niri/workspaces",
        "niri/window"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "custom/mounts", 
        "custom/backup", // L'ho aggiunto qui cos√¨ lo vedi quando parte!
        "tray",
        "custom/updates",
        "temperature",
        "cpu",
        "memory",
        "disk",
        "custom/nightlight",
        "bluetooth",
        "pulseaudio#microphone",
        "pulseaudio",
        "battery",
        "network",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "ůĪĄÖ",
        "on-click": "fuzzel",
        "tooltip": false
    },

    "custom/power": {
        "format": "‚ŹĽ",
        "on-click": "niri msg action quit",
        "tooltip": false
    },

    "niri/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "active": "‚óŹ",
            "default": "‚óč"
        }
    },

    "niri/window": {
        "format": "{}",
        "max-length": 40,
        "rewrite": {
            "(.*) ‚ÄĒ Mozilla Firefox": "ůįąĻ $1",
            "(.*) - kitty": " $1",
            "(.*)": "$1"
        }
    },

    "tray": {
        "icon-size": 12,
        "spacing": 10
    },

    "clock": {
        "timezone": "Europe/Rome",
        "format": "  {:%H:%M}",
        "tooltip": true,
        "tooltip-format": "  {:%A, %d %B %Y}\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "interval": 10,
        "format": "ůįėö",
        "format-alt-click": "click-right",
        "format-alt": "ůįėö {usage}%",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}% | Load: {load}"
    },

    "memory": {
        "interval": 30,
        "format": "ůįćõ",
        "format-alt-click": "click-right",
        "format-alt": "ůįćõ {used:0.1f}G",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}GB / {total:0.1f}GB ({percentage}%)"
    },

    "disk": {
        "interval": 600,
        "format": "ůįčä",
        "path": "/",
        "format-alt-click": "click-right",
        "format-alt": "ůįčä {percentage_used}%",
        "tooltip": true,
        "tooltip-format": "Disco: {used} / {total} ({percentage_used}%)",
        "states": {
            "warning": 85,
            "critical": 90
        }
    },

    "temperature": {
        "thermal-zone": 1,
        "format": "ůįĒŹ",
        "format-alt-click": "click-right",
        "format-alt": "ůįĒŹ {temperatureC}¬įC",
        "critical-threshold": 70,
        "format-critical": "ůįłĀ {temperatureC}¬įC",
        "tooltip": true,
        "tooltip-format": "Temperatura: {temperatureC}¬įC"
    },

    "battery": {
        "bat": "BAT0",
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}",
        "format-charging": "ůįāĄ {capacity}%",
        "format-plugged": "ůįö• {capacity}%",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["ůįāé", "ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"],
        "tooltip": true,
        "tooltip-format": "Batteria: {capacity}% ({timeTo})"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "ůįĚü",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ůįčč",
            "hands-free": "ůįčč",
            "headset": "ůįčč",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"]
        },
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ůįć¨",
        "format-source-muted": "ůįć≠",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%-",
        "tooltip": true,
        "tooltip-format": "Mic: {volume}%"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {percent}%",
        "format-icons": ["ůįÉě", "ůįÉü", "ůįÉ†"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": true,
        "tooltip-format": "Luminosit√†: {percent}%"
    },

    "network": {
        "format-wifi": "ůį§®",
        "format-ethernet": "ůįąÄ",
        "format-disconnected": "ůį§≠",
        "tooltip-format-wifi": "ůį§® {essid} ({signalStrength}%)\nůį©ü {ipaddr}/{cidr}",
        "tooltip-format-ethernet": "ůįąÄ {ifname}\nůį©ü {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnesso",
        "max-length": 50
    },

    "custom/updates": {
        "format": "{}",
        "exec": "apt list --upgradable 2>/dev/null | tail -n +2 | wc -l | xargs -I{} echo '{} ůįöį'",
        "interval": 3600,
        "tooltip": true,
        "tooltip-format": "Aggiornamenti disponibili"
    },

    "custom/mounts": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/mounts.sh waybar",
        "return-type": "json",
        "interval": 10,
        "on-click": "~/.config/waybar/scripts/mounts.sh toggle",
        "tooltip": true
    },

    "custom/backup": {
        "exec": "pgrep -x rsync > /dev/null && echo 'ůįĀĮ BACKUP' || echo ''",
        "interval": 5,
        "tooltip": false
    },

    "custom/nightlight": {
        "format": "{}",
        "return-type": "json",
        "interval": 2,
        "exec": "~/.config/waybar/scripts/nightlight.sh status",
        "on-click": "~/.config/waybar/scripts/nightlight.sh toggle"
    },

    "bluetooth": {
        "format": "ůįāĮ",
        "format-disabled": "ůįā≤",
        "format-connected": "ůįāĪ {num_connections}",
        "on-click": "/usr/sbin/rfkill toggle bluetooth", // <--- PERCORSO COMPLETO
        "on-click-right": "blueman-manager"
    }
}
