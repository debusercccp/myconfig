{
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 40,           // Lascia solo questa
    "margin-right": 5,
    "margin-left": 5,
    "output": "eDP-1",

    "modules-left": [
        "custom/launcher",
        "niri/workspaces",
        "niri/window"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "custom/mounts", 
        "custom/backup", // L'ho aggiunto qui cos├¼ lo vedi quando parte!
        "tray",
        "custom/updates",
        "temperature",
        "cpu",
        "memory",
        "disk",
        "custom/nightlight",
        "bluetooth",
        "pulseaudio#microphone",
        "pulseaudio",
        "battery",
        "network",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "¾▒äà",
        "on-click": "fuzzel",
        "tooltip": false
    },

    "custom/power": {
        "format": "ÔÅ╗",
        "on-click": "niri msg action quit",
        "tooltip": false
    },

    "niri/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "active": "ÔùÅ",
            "default": "Ôùï"
        }
    },

    "niri/window": {
        "format": "{}",
        "max-length": 40,
        "rewrite": {
            "(.*) ÔÇö Mozilla Firefox": "¾░ê╣ $1",
            "(.*) - kitty": " $1",
            "(.*)": "$1"
        }
    },

    "tray": {
        "icon-size": 12,
        "spacing": 10
    },

    "clock": {
        "timezone": "Europe/Rome",
        "format": "  {:%H:%M}",
        "tooltip": true,
        "tooltip-format": "  {:%A, %d %B %Y}\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "interval": 10,
        "format": "¾░ÿÜ",
        "format-alt-click": "click-right",
        "format-alt": "¾░ÿÜ {usage}%",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}% | Load: {load}"
    },

    "memory": {
        "interval": 30,
        "format": "¾░ìø",
        "format-alt-click": "click-right",
        "format-alt": "¾░ìø {used:0.1f}G",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}GB / {total:0.1f}GB ({percentage}%)"
    },

    "disk": {
        "interval": 600,
        "format": "¾░ïè",
        "path": "/",
        "format-alt-click": "click-right",
        "format-alt": "¾░ïè {percentage_used}%",
        "tooltip": true,
        "tooltip-format": "Disco: {used} / {total} ({percentage_used}%)",
        "states": {
            "warning": 85,
            "critical": 90
        }
    },

    "temperature": {
        "thermal-zone": 1,
        "format": "¾░öÅ",
        "format-alt-click": "click-right",
        "format-alt": "¾░öÅ {temperatureC}┬░C",
        "critical-threshold": 70,
        "format-critical": "¾░©ü {temperatureC}┬░C",
        "tooltip": true,
        "tooltip-format": "Temperatura: {temperatureC}┬░C"
    },

    "battery": {
        "bat": "BAT0",
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}",
        "format-charging": "¾░éä {capacity}%",
        "format-plugged": "¾░ÜÑ {capacity}%",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"],
        "tooltip": true,
        "tooltip-format": "Batteria: {capacity}% ({timeTo})"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "¾░Øƒ",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "¾░ïï",
            "hands-free": "¾░ïï",
            "headset": "¾░ïï",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
        },
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "¾░ì¼",
        "format-source-muted": "¾░ì¡",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%-",
        "tooltip": true,
        "tooltip-format": "Mic: {volume}%"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {percent}%",
        "format-icons": ["¾░â×", "¾░âƒ", "¾░âá"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": true,
        "tooltip-format": "Luminosit├á: {percent}%"
    },

    "network": {
        "format-wifi": "¾░ñ¿",
        "format-ethernet": "¾░êÇ",
        "format-disconnected": "¾░ñ¡",
        "tooltip-format-wifi": "¾░ñ¿ {essid} ({signalStrength}%)\n¾░®ƒ {ipaddr}/{cidr}",
        "tooltip-format-ethernet": "¾░êÇ {ifname}\n¾░®ƒ {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnesso",
        "max-length": 50
    },

    "custom/updates": {
        "format": "{}",
        "exec": "apt list --upgradable 2>/dev/null | tail -n +2 | wc -l | xargs -I{} echo '{} ¾░Ü░'",
        "interval": 3600,
        "tooltip": true,
        "tooltip-format": "Aggiornamenti disponibili"
    },

    "custom/mounts": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/mounts.sh waybar",
        "return-type": "json",
        "interval": 10,
        "on-click": "~/.config/waybar/scripts/mounts.sh toggle",
        "tooltip": true
    },

    "custom/backup": {
        "exec": "pgrep -x rsync > /dev/null && echo '¾░ü» BACKUP' || echo ''",
        "interval": 5,
        "tooltip": false
    },

    "custom/nightlight": {
        "format": "{}",
        "return-type": "json",
        "interval": 2,
        "exec": "~/.config/waybar/scripts/nightlight.sh status",
        "on-click": "~/.config/waybar/scripts/nightlight.sh toggle"
    },

    "bluetooth": {
        "format": "¾░é»",
        "format-disabled": "¾░é▓",
        "format-connected": "¾░é▒ {num_connections}",
        "on-click": "/usr/sbin/rfkill toggle bluetooth", // <--- PERCORSO COMPLETO
        "on-click-right": "blueman-manager"
    }
}
