#!/usr/bin/env bash
# Script di aggiornamento per NixOS e Debian/Ubuntu (Ottimizzato per Waybar)

# Rilevamento della Distribuzione
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS=$ID
else
    OS="unknown"
fi

case "$1" in
    update)
        if [ "$OS" = "nixos" ]; then
            # Aggiorna il Flake ed esegue il rebuild su Kitty
            kitty --hold bash -c "cd ~/myconfig-nix && nix flake update && sudo nixos-rebuild switch --flake .#lynx"
        elif [ "$OS" = "debian" ] || [ "$OS" = "ubuntu" ]; then
            kitty bash -c "sudo apt update && sudo apt upgrade -y"
        fi
        pkill -SIGRTMIN+8 waybar
        exit 0
        ;;
    *)
        # Output JSON puro per Waybar (Evita calcoli pesanti o stringhe di errore nel PATH)
        if [ "$OS" = "nixos" ]; then
            # Su NixOS il concetto di "numero di aggiornamenti staccati" non esiste nativamente.
            # Mostriamo un'icona pulita di sistema pronto.
            printf '{"text": " NixOS", "tooltip": "Sistema Gestito via Flake\\nClick per aggiornare il repository ed eseguire il rebuild"}\n'
        elif [ "$OS" = "debian" ] || [ "$OS" = "ubuntu" ]; then
            COUNT=$(apt-get upgrade -s 2>/dev/null | grep -P '^Inst' | wc -l)
            if [ "$COUNT" = "0" ]; then
                printf '{"text": " APT", "tooltip": "Sistema Debian aggiornato"}\n'
            else
                printf '{"text": " %s", "tooltip": "%s aggiornamenti APT disponibili"}\n' "$COUNT" "$COUNT"
            fi
        else
            printf '{"text": " OS", "tooltip": "Sistema Operativo Sconosciuto"}\n'
        fi
        ;;
esac
