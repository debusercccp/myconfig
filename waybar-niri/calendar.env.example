# Segreti del calendario. Copia questo file in calendar.env e inserisci il
# valore reale. calendar.env e' escluso da git e viene caricato in automatico
# da cal-sync.py (righe KEY=VALUE).
#
# Il nome qui usato (GCAL_ICS_URL) deve combaciare con quello in calendar.conf
# (ICS_URL=$GCAL_ICS_URL).
#
# In alternativa puoi NON usare questo file ed esportare la variabile altrove
# (es. nel tuo ~/.profile o nell'ambiente di niri), purche' sia visibile a waybar.

GCAL_ICS_URL=https://calendar.google.com/calendar/ical/xxxxxxxx%40group.calendar.google.com/private-xxxxxxxx/basic.ics
