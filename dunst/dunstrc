[global]
    ### Aspetto Generale ###
    font = JetBrainsMono Nerd Font 10
    allow_markup = yes
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Geometria ###
    width = 300
    height = 200
    origin = top-right
    offset = 10x50
    shrink = no
    transparency = 10
    padding = 15
    horizontal_padding = 15
    frame_width = 2
    corner_radius = 10  # Si abbina ai tuoi window-rule di Niri

    ### Colori Dracula ###
    frame_color = "#bd93f9"
    separator_color = "frame"

[urgency_low]
    background = "#282a36"
    foreground = "#6272a4"
    timeout = 5

[urgency_normal]
    background = "#282a36"
    foreground = "#f8f8f2"
    timeout = 10
    # Bordo rosa per le notifiche normali
    frame_color = "#ff79c6"

[urgency_critical]
    background = "#282a36"
    foreground = "#ff5555"
    frame_color = "#ff5555"
    timeout = 0
